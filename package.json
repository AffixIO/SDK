    "affix-sdk-web": "./dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {}
