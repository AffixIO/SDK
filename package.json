  "repository": {
    "type": "git",
    "url": "git+https://github.com/AffixIO/SDK.git"
  },
  "bugs": {
    "url": "https://github.com/AffixIO/SDK/issues"
  },
  "keywords": [
    "post-quantum-cryptography",
    "post-quantum",
    "quantum-safe",
    "quantum-resistant",
    "zero-knowledge",
    "zero-knowledge-proofs",
    "zkp",
    "zk-snark",
    "snark",
    "noir",
    "noir-lang",
    "barretenberg",
    "ultrahonk",
    "ml-dsa",
    "fips-204",
    "fips-203",
    "fips-205",
    "crystals-dilithium",
    "privacy-preserving",
    "verifiable-credentials",
    "attestation",
    "kyc",
    "identity",
    "merkle",
    "proof",
    "prove",
    "verify",
    "nodejs",
    "typescript",
    "affixio"
  ],
  "files": [
    "dist",
    "certs",
    ".env.example",
    "README.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "AUTHORS"
